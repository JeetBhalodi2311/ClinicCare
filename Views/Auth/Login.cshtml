@model FrontendEXAM.Models.LoginRequest

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="login-wrapper">
    <div class="login-card card">
        <div class="login-header">
            <i class="bi bi-hospital" style="font-size: 2.5rem;"></i>
            <h2 class="mt-2">ClinicCare</h2>
            <p>Sign in to your account</p>
        </div>
        <div class="card-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="control-label fw-bold">
                        <i class="bi bi-envelope me-1"></i>Email
                    </label>
                    <input asp-for="Email" class="form-control" type="email" required placeholder="you@clinic.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Password" class="control-label fw-bold">
                        <i class="bi bi-lock me-1"></i>Password
                    </label>
                    <input asp-for="Password" class="form-control" type="password" required placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-group d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
