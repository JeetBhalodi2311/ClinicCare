@model FrontendEXAM.Models.AddPrescriptionRequest

@{
    ViewData["Title"] = "Add Prescription";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2><i class="bi bi-capsule me-2"></i>Add Prescription</h2>
    <a asp-action="Dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Queue</a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-gradient-primary text-white">
        <h5 class="mb-0"><i class="bi bi-file-earmark-medical me-2"></i>Prescription Form</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="AddPrescription" method="post">
            <input type="hidden" name="id" value="@ViewBag.AppointmentId" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group mb-4">
                <label asp-for="Notes" class="control-label fw-bold">
                    <i class="bi bi-journal-text me-1"></i>Doctor's Notes
                </label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="General instructions, diet, next visit..."></textarea>
            </div>

            <h5 class="mb-3"><i class="bi bi-prescription2 me-2"></i>Medicines</h5>

            <div id="medicinesContainer">
                @if (Model?.Medicines != null && Model.Medicines.Any())
                {
                    for (int i = 0; i < Model.Medicines.Count; i++)
                    {
                        <div class="medicine-row row mb-3 align-items-end p-2 bg-light rounded">
                            <div class="col-md-4 form-group">
                                <label class="small fw-bold">Name</label>
                                <input name="Medicines[@i].Name" value="@Model.Medicines[i].Name" class="form-control" placeholder="Paracetamol" required />
                            </div>
                            <div class="col-md-3 form-group">
                                <label class="small fw-bold">Dosage</label>
                                <input name="Medicines[@i].Dosage" value="@Model.Medicines[i].Dosage" class="form-control" placeholder="500mg" required />
                            </div>
                            <div class="col-md-3 form-group">
                                <label class="small fw-bold">Duration</label>
                                <input name="Medicines[@i].Duration" value="@Model.Medicines[i].Duration" class="form-control" placeholder="5 days" required />
                            </div>
                            <div class="col-md-2 form-group">
                                <button type="button" class="btn btn-danger btn-sm remove-btn mt-4"><i class="bi bi-x-lg"></i></button>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="mb-4 mt-2">
                <button type="button" id="addMedicineBtn" class="btn btn-outline-info">
                    <i class="bi bi-plus-circle me-1"></i>Add Another Medicine
                </button>
            </div>

            <div class="form-group mt-4 pt-3 border-top d-grid">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-circle me-2"></i>Save Prescription
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let rowIdx = @(Model?.Medicines?.Count ?? 0);

            $('#addMedicineBtn').click(function () {
                const newRow = `
                    <div class="medicine-row row mb-3 align-items-end p-2 bg-light rounded">
                        <div class="col-md-4 form-group">
                            <label class="small fw-bold">Name</label>
                            <input name="Medicines[${rowIdx}].Name" class="form-control" placeholder="Medicine name" required />
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="small fw-bold">Dosage</label>
                            <input name="Medicines[${rowIdx}].Dosage" class="form-control" placeholder="500mg" required />
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="small fw-bold">Duration</label>
                            <input name="Medicines[${rowIdx}].Duration" class="form-control" placeholder="5 days" required />
                        </div>
                        <div class="col-md-2 form-group">
                            <button type="button" class="btn btn-danger btn-sm remove-btn mt-4"><i class="bi bi-x-lg"></i></button>
                        </div>
                    </div>`;

                $('#medicinesContainer').append(newRow);
                rowIdx++;
            });

            $(document).on('click', '.remove-btn', function () {
                $(this).closest('.medicine-row').remove();
            });
        });
    </script>
}
