@model IEnumerable<FrontendEXAM.Models.Appointment>

@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2><i class="bi bi-calendar-check me-2"></i>My Appointments</h2>
    <a asp-action="Book" class="btn btn-primary"><i class="bi bi-calendar-plus me-2"></i>Book New Appointment</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
}

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var apt in Model.OrderByDescending(a => a.AppointmentDate).ThenByDescending(a => a.TimeSlot))
        {
            var statusClass = apt.Status?.ToLower() switch {
                "completed" or "done" => "status-completed",
                "cancelled" => "status-cancelled",
                "in_progress" => "status-in-progress",
                "queued" or "scheduled" => "status-waiting",
                _ => "status-waiting"
            };
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0" style="color: var(--primary);">
                                <i class="bi bi-calendar-event me-1"></i>Appointment
                            </h5>
                            <span class="badge @statusClass">@apt.Status?.ToUpper()</span>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>@apt.AppointmentDate
                                <span class="mx-2">|</span>
                                <i class="bi bi-clock me-1"></i>@apt.TimeSlot
                            </span>
                        </div>
                        @if (apt.QueueEntry != null)
                        {
                            <div class="mb-3">
                                <span class="badge bg-secondary"><i class="bi bi-hash"></i>Token: @apt.QueueEntry.TokenNumber</span>
                            </div>
                        }
                        <a asp-action="Details" asp-route-id="@apt.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>View Details & Prescription
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="empty-state">
                <i class="bi bi-calendar-x"></i>
                <h5 class="text-muted mt-3">You have no appointments.</h5>
                <p class="text-muted">Click "Book New Appointment" to schedule one.</p>
            </div>
        </div>
    }
</div>
