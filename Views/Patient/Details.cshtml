@model FrontendEXAM.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="mb-4 mt-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-file-earmark-medical me-2"></i>Appointment Details</h2>
        <a asp-action="Dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error</div>
}
else if (Model != null && Model.Id > 0)
{
    var statusClass = Model.Status?.ToLower() switch {
        "completed" or "done" => "status-completed",
        "cancelled" => "status-cancelled",
        "in_progress" => "status-in-progress",
        _ => "status-waiting"
    };

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-gradient-info text-white">
                    <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Basic Info</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4"><i class="bi bi-calendar3 me-1"></i>Date</dt>
                        <dd class="col-sm-8">@Model.AppointmentDate</dd>

                        <dt class="col-sm-4"><i class="bi bi-clock me-1"></i>Time</dt>
                        <dd class="col-sm-8">@Model.TimeSlot</dd>

                        <dt class="col-sm-4"><i class="bi bi-flag me-1"></i>Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @statusClass">@Model.Status?.ToUpper()</span>
                        </dd>

                        @if (Model.QueueEntry != null)
                        {
                            <dt class="col-sm-4"><i class="bi bi-hash me-1"></i>Token</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-secondary fs-6">#@Model.QueueEntry.TokenNumber</span>
                            </dd>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-gradient-green text-white">
                    <h5 class="mb-0"><i class="bi bi-capsule me-2"></i>Prescription</h5>
                </div>
                <div class="card-body">
                    @if (Model.Prescription != null)
                    {
                        @if (!string.IsNullOrEmpty(Model.Prescription.Notes))
                        {
                            <div class="mb-3 p-3 bg-light rounded">
                                <strong><i class="bi bi-journal-text me-1"></i>Notes:</strong>
                                <p class="mb-0 mt-1">@Model.Prescription.Notes</p>
                            </div>
                        }

                        @if (Model.Prescription.Medicines != null && Model.Prescription.Medicines.Any())
                        {
                            <h6 class="fw-bold mb-2"><i class="bi bi-prescription2 me-1"></i>Medicines</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Medicine</th>
                                            <th>Dosage</th>
                                            <th>Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var med in Model.Prescription.Medicines)
                                        {
                                            <tr>
                                                <td class="fw-bold">@med.Name</td>
                                                <td>@med.Dosage</td>
                                                <td><span class="badge bg-info">@med.Duration</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted fst-italic mb-0"><i class="bi bi-hourglass-split me-1"></i>No prescription has been added yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-gradient-purple text-white">
                    <h5 class="mb-0"><i class="bi bi-clipboard2-pulse me-2"></i>Doctor's Report</h5>
                </div>
                <div class="card-body">
                    @if (Model.Report != null)
                    {
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <span class="badge bg-danger mb-2">Diagnosis</span>
                                <p class="fw-bold">@Model.Report.Diagnosis</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <span class="badge bg-warning text-dark mb-2">Tests Recommended</span>
                                <p>@Model.Report.TestRecommended</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <span class="badge bg-info mb-2">Remarks</span>
                                <p>@Model.Report.Remarks</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted fst-italic mb-0"><i class="bi bi-hourglass-split me-1"></i>No report has been added yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-circle me-2"></i>Appointment not found.</div>
}
